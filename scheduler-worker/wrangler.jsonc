{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "blog-test2-scheduler",
  "main": "src/index.js",
  "compatibility_date": "2026-07-11",
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "PAGES_BASE_URL": "https://blog-test2-k36.pages.dev"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "blog-news-db",
      "database_id": "885000de-6b5f-40f8-993e-75e837897a44"
    }
  ]
}
