{
  "name": "blog-test2-publisher",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run save-draft",
    "login-check": "node src/index.js --login-check",
    "dry-run": "node src/index.js --dry-run",
    "save-draft": "node src/index.js --save-draft",
    "watch": "node src/watch.js",
    "publish": "node src/index.js --publish",
    "check": "node --check src/index.js && node --check src/watch.js && node --check src/image-processing.js && node --check src/naver-selectors.js",
    "test": "node --test test/*.test.js"
  },
  "dependencies": { "playwright": "^1.53.0", "sharp": "^0.34.3" }
}
